diff --git a/src/re_bytes.rs b/src/re_bytes.rs
index c804722..8fdb133 100644
--- a/src/re_bytes.rs
+++ b/src/re_bytes.rs
@@ -1065,7 +1065,8 @@ impl<'c, 't> Iterator for SubCaptureMatches<'c, 't> {
 ///
