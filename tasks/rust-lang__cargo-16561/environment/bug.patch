-pub fn redundant_homepage(
-    pkg: &Package,
-    manifest_path: &Path,
-    cargo_lints: &TomlToolLints,
-    error_count: &mut usize,
-    gctx: &GlobalContext,
-) -> CargoResult<()> {
-    let (lint_level, reason) = LINT.level(
-        cargo_lints,
