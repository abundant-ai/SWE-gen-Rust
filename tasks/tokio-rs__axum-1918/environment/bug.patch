-        }
-
-        let routes = self
-            .routes
-            .into_iter()
-            .map(|(id, endpoint)| {
-                let route = endpoint.layer(layer.clone());
-                (id, route)
-            })
-            .collect();
-
-        PathRouter {
-            routes,
-            node: self.node,
-        }
-    }
