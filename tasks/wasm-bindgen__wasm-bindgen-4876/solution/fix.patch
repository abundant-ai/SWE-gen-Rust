-            IdlType::Short => Ok(Some(ident_ty(raw_ident("i16")))),
-            IdlType::UnsignedShort => Ok(Some(ident_ty(raw_ident("u16")))),
-            IdlType::Long => Ok(Some(ident_ty(raw_ident("i32")))),
