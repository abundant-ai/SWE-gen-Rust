+            .cloned()
+            .collect();
+
+        Ok(FnClassGenerics {
+            class_generic_params,
+            class_generic_exprs,
+            class_bounds,
+            fn_generic_params,
+            fn_bounds,
+            concrete_defaults,
+            class_lifetime_params,
+            class_bound_lifetime_params,
+            fn_lifetime_params,
+        })
+    }
+}
