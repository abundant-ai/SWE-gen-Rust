+fn character(input: &str) -> IResult<&str, char> {
+  let (input, c) = none_of("\"")(input)?;
+  if c == '\\' {
+    alt((
+      map_res(anychar, |c| {
+        Ok(match c {
+          '"' | '\\' | '/' => c,
+          'b' => '\x08',
+          'f' => '\x0C',
+          'n' => '\n',
+          'r' => '\r',
+          't' => '\t',
+          _ => return Err(()),
+        })
+      }),
+      map(
+        map_res(preceded(char('u'), take(4usize)), |s| {
+          u16::from_str_radix(s, 16)
+        }),
+        |c| unsafe { std::char::from_u32_unchecked(c as u32) },
+      ),
+    ))(input)
+  } else {
+    Ok((input, c))
+  }
+}
 
