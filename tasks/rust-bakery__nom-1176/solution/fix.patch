+fn term(input: &[u8]) -> IResult<&[u8], i64> {
+  let (input, init) = factor(input)?;
+  fold_many0(pair(one_of("*/"), factor), init, |acc, (op, val)| {
+    if op == '*' {
+      acc * val
+    } else {
+      acc / val
+    }
+  })(input)
+}
 
