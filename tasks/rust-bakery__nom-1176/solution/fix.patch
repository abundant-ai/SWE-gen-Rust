+// If there are no digits, we look for a parenthesized expression.
+fn factor(input: &[u8]) -> IResult<&[u8], i64> {
+  delimited(
+    space0,
+    alt((
+      map_res(digit1, |digits| {
+        unsafe { std::str::from_utf8_unchecked(digits) }.parse()
+      }),
+      delimited(char('('), expr, char(')')),
+    )),
+    space0,
+  )(input)
+}
 
