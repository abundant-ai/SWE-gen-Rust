+fn expr(input: &[u8]) -> IResult<&[u8], i64> {
+  let (input, init) = term(input)?;
+  fold_many0(pair(one_of("+-"), term), init, |acc, (op, val)| {
+    if op == '+' {
+      acc + val
+    } else {
+      acc - val
+    }
+  })(input)
+}
 
