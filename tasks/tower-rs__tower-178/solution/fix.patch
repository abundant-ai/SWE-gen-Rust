diff --git a/tower-filter/src/predicate.rs b/tower-filter/src/predicate.rs
new file mode 100644
index 0000000..32569c7
--- /dev/null
+++ b/tower-filter/src/predicate.rs
@@ -0,0 +1,21 @@
+use error::Error;
+use futures::{Future, IntoFuture};
+
+/// Checks a request
+pub trait Predicate<Request> {
+    type Future: Future<Item = (), Error = Error>;
+
+    fn check(&mut self, request: &Request) -> Self::Future;
+}
+
+impl<F, T, U> Predicate<T> for F
+where
+    F: Fn(&T) -> U,
+    U: IntoFuture<Item = (), Error = Error>,
+{
+    type Future = U::Future;
+
+    fn check(&mut self, request: &T) -> Self::Future {
+        self(request).into_future()
+    }
+}
