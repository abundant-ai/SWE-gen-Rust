+    let request = handle.next_request().unwrap();
+    assert_eq!("one", request.as_str());
+    request.respond("resp-one".into());
+
+    let request = handle.next_request().unwrap();
+    assert_eq!("two", request.as_str());
+    request.respond("resp-two".into());
+
+    th1.join().unwrap();
+    th2.join().unwrap();
