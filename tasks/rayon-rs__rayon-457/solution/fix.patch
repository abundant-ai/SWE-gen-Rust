+#[test]
+pub fn check_enumerate_rev() {
+    let a: Vec<usize> = (0..1024).rev().collect();
+
+    let mut b = vec![];
+    a.par_iter()
+        .enumerate()
+        .rev()
+        .map(|(i, &x)| i + x)
+        .collect_into(&mut b);
+    assert!(b.iter().all(|&x| x == a.len() - 1));
+}
