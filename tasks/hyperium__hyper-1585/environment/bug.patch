-                trace!("no idle yet; tick count: {}", tick_cnt);
-                ::futures::task::current().notify();
-                Ok(Async::NotReady)
-            } else {
-                Ok::<_, ()>(Async::Ready(()))
-            }
-        });
-        rt.block_on(fut).unwrap();
-    }
