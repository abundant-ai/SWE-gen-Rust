-#[test]
-fn checkout_win_allows_connect_future_to_be_pooled() {
-    let _ = pretty_env_logger::try_init();
-
-    let mut rt = Runtime::new().expect("new rt");
-    let mut connector = MockConnector::new();
-
-
-    let (tx, rx) = oneshot::channel::<()>();
