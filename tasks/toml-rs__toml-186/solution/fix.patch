+                    ))
+                } else if v.len() != 1 {
+                    Err(crate::easy::de::Error::custom(
+                        "wanted exactly 1 element, more than 1 element",
+                    ))
+                } else {
+                    visitor.visit_enum(crate::easy::de::TableMapAccess::new(v))
