+    /// [`SigningKey`]: crate::crypto::signer::SigningKey
+    Unknown,
+}
+
+impl From<InconsistentKeys> for Error {
+    #[inline]
+    fn from(e: InconsistentKeys) -> Self {
+        Self::InconsistentKeys(e)
