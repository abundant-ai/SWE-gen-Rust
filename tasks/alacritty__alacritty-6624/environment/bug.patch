commit efce55ab545284a18ff0e974a4f4b5e987542e23
Author: Christian Duerr <contact@christianduerr.com>
Date:   Sun Jan 15 23:26:07 2023 +0100

    Preserve last column with erase in line right
    
    When the erase in line escape sequence with a parameter of 0 (right) is
    passed while the wrapline flag is already set, it will no longer clear
    the last column and instead ignore the operation.
    
    The behavior of `\e[1K` and `\e[2K` is unchanged and both will clear the
    entire first line without clearing the wrapline flag.
    
    Closes #6159.

diff --git b/CHANGELOG.md a/CHANGELOG.md
index f2c8ce41..dddfcb45 100644
--- b/CHANGELOG.md
+++ a/CHANGELOG.md
@@ -15,7 +15,6 @@ The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.0.0/).
 
 - `font.glyph_offset.y` is now applied to underline/strikeout
 - Always use sRGB color space on macOS
-- Erase in line after the last column will no longer clear the last column
 
 ### Fixed
 
diff --git b/alacritty_terminal/src/term/mod.rs a/alacritty_terminal/src/term/mod.rs
index e41120da..98f76d52 100644
--- b/alacritty_terminal/src/term/mod.rs
+++ a/alacritty_terminal/src/term/mod.rs
@@ -1458,7 +1458,6 @@ impl<T: EventListener> Handler for Term<T> {
         let point = cursor.point;
 
         let (left, right) = match mode {
-            ansi::LineClearMode::Right if cursor.input_needs_wrap => return,
             ansi::LineClearMode::Right => (point.column, Column(self.columns())),
             ansi::LineClearMode::Left => (Column(0), point.column + 1),
             ansi::LineClearMode::All => (Column(0), Column(self.columns())),
