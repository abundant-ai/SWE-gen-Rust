-        fn endline(&mut self) {
-            if self.dirty_line {
-                self.newline();
-            }
-        }
-        fn new_paragraph(&mut self) {
-            self.endline();
-            self.hanging_paragraph = true;
-        }
-
-        fn write_fmt(&mut self, arguments: fmt::Arguments<'_>) {
