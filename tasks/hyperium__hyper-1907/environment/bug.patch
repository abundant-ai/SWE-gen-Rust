-        Ok(()).into()
-    }
-
-    fn call(&mut self, _: T) -> Self::Future {
-        future::ok(Svc)
-    }
-}
-
-#[tokio::main]
-async fn main() -> Result<(), Box<dyn std::error::Error>> {
-    pretty_env_logger::init();
-
-    let addr = "127.0.0.1:1337".parse().unwrap();
-
-
-    let server = Server::bind(&addr)
-        .serve(MakeSvc);
-
-    println!("Listening on http://{}", addr);
-
-    server.await?;
-
-    Ok(())
-}
