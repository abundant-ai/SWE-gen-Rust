+                    .filter(|pos| !pos.is_last_set())
+                    .map(|pos| format!(" {}", pos.stylized(Some(false))))
+                    .collect::<Vec<_>>()
+                    .join(""),
+            )
+        } else {
+            Some("".into())
+        }
+    }
