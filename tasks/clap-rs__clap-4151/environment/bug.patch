+        } else if !incl_reqs {
+            debug!(
+                "Usage::get_optional_args:iter: incl_reqs=false, building secondary usage string"
+            );
+            let highest_req_pos = self
+                .cmd
+                .get_positionals()
+                .filter_map(|pos| {
+                    if pos.is_required_set() && !pos.is_last_set() {
+                        Some(pos.index)
