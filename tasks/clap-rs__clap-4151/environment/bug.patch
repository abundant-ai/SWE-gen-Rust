+                debug!(
+                    "Usage::get_optional_args:iter:{:?}:iter:{:?}",
+                    pos.get_id(),
+                    grp_s
+                );
+                // if it's part of a required group we don't want to count it
+                self.cmd.get_groups().any(|g| g.required && (g.id == grp_s))
