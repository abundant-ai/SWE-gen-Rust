-    let client = Reconnect::new(maker, dst);
-
-    let request = Request::builder()
-        .method("GET")
-        .body(Body::from(Vec::new()))
-        .unwrap();
-
-    // we check to see if the client is ready to accept requests.
     client
-        .ready()
