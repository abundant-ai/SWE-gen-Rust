@@ -42,18 +42,17 @@ fn request() -> impl Future<Item = Response<hyper::Body>, Error = ()> {
         .buffer(5)
         .make_service(hyper);
 
-    // `Reconnect` accepts a destination and a MakeService, creating a new service
