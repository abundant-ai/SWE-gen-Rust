+// pub(crate)
+
+pub fn intercept(proxy: &Proxy, uri: &Uri) -> Option<Uri> {
+    proxy.intercept(uri)
+}
+
+pub fn is_proxied(proxies: &[Proxy], uri: &Url) -> bool {
+    proxies.iter().any(|p| p.proxies(uri))
+}
