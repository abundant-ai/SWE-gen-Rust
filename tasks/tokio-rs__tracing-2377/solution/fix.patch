new file mode 100644
index 00000000..a21f260e
--- /dev/null
+++ b/tracing-mock/src/expect.rs
@@ -0,0 +1,43 @@
+use crate::{
+    event::ExpectedEvent,
+    field::{ExpectedField, ExpectedFields, ExpectedValue},
+    span::{ExpectedSpan, NewSpan},
+};
+
+#[derive(Debug, Eq, PartialEq)]
+pub(crate) enum Expect {
+    Event(ExpectedEvent),
+    FollowsFrom {
+        consequence: ExpectedSpan,
+        cause: ExpectedSpan,
+    },
+    Enter(ExpectedSpan),
+    Exit(ExpectedSpan),
+    CloneSpan(ExpectedSpan),
+    DropSpan(ExpectedSpan),
+    Visit(ExpectedSpan, ExpectedFields),
+    NewSpan(NewSpan),
+    Nothing,
+}
+
+pub fn event() -> ExpectedEvent {
+    ExpectedEvent {
+        ..Default::default()
+    }
+}
+
+pub fn field<K>(name: K) -> ExpectedField
+where
+    String: From<K>,
+{
+    ExpectedField {
+        name: name.into(),
+        value: ExpectedValue::Any,
+    }
+}
+
+pub fn span() -> ExpectedSpan {
+    ExpectedSpan {
+        ..Default::default()
+    }
+}
