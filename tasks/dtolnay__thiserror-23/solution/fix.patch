+
+fn find_duplicate_source(fields: &[Field]) -> Result<()> {
+    let mut has_source = false;
+    for field in fields {
+        if let Some(source) = &field.attrs.source {
+            if has_source {
+                return Err(Error::new_spanned(
+                    source.original,
+                    "duplicate #[source] attribute",
+                ));
+            }
+            has_source = true;
+        }
+    }
+    Ok(())
+}
