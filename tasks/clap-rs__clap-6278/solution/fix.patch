diff --git a/clap_builder/src/util/escape.rs b/clap_builder/src/util/escape.rs
new file mode 100644
index 00000000..69c2103b
--- /dev/null
+++ b/clap_builder/src/util/escape.rs
@@ -0,0 +1,29 @@
+#[cfg(feature = "help")]
+use std::borrow::Cow;
+
+pub(crate) struct Escape<'s>(pub(crate) &'s str);
+
+impl<'s> Escape<'s> {
+    pub(crate) fn needs_escaping(&self) -> bool {
+        self.0.is_empty() || self.0.contains(char::is_whitespace)
+    }
+
+    #[cfg(feature = "help")]
+    pub(crate) fn to_cow(&self) -> Cow<'s, str> {
+        if self.needs_escaping() {
+            Cow::Owned(format!("{:?}", self.0))
+        } else {
+            Cow::Borrowed(self.0)
+        }
+    }
+}
+
+impl std::fmt::Display for Escape<'_> {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        if self.needs_escaping() {
+            std::fmt::Debug::fmt(self.0, f)
+        } else {
+            self.0.fmt(f)
+        }
+    }
+}
