diff --git a/tower-util/src/service_fn.rs b/tower-util/src/service_fn.rs
index f109d6b..a2472ae 100644
--- a/tower-util/src/service_fn.rs
+++ b/tower-util/src/service_fn.rs
@@ -1,5 +1,4 @@
-use std::future::Future;
-use std::task::{Context, Poll};
+use futures::{IntoFuture, Poll};
 use tower_service::Service;
 
 /// Returns a new `ServiceFn` with the given closure.
@@ -13,20 +12,20 @@ pub struct ServiceFn<T> {
     f: T,
 }
 
-impl<T, F, Request, R, E> Service<Request> for ServiceFn<T>
+impl<T, F, Request> Service<Request> for ServiceFn<T>
 where
     T: FnMut(Request) -> F,
-    F: Future<Output = Result<R, E>>,
+    F: IntoFuture,
 {
-    type Response = R;
-    type Error = E;
-    type Future = F;
+    type Response = F::Item;
+    type Error = F::Error;
+    type Future = F::Future;
 
-    fn poll_ready(&mut self, _: &mut Context<'_>) -> Poll<Result<(), E>> {
-        Ok(()).into()
+    fn poll_ready(&mut self) -> Poll<(), F::Error> {
+        Ok(().into())
     }
 
     fn call(&mut self, req: Request) -> Self::Future {
-        (self.f)(req)
+        (self.f)(req).into_future()
     }
 }
