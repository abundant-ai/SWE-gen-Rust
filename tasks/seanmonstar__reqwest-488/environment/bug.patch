-/// Convert a time::Tm time to SystemTime.
-fn tm_to_systemtime(tm: ::time::Tm) -> SystemTime {
-    let seconds = tm.to_timespec().sec;
-    let duration = std::time::Duration::from_secs(seconds.abs() as u64);
-    if seconds > 0 {
-        SystemTime::UNIX_EPOCH + duration
-    } else {
-        SystemTime::UNIX_EPOCH - duration
-    }
-}
