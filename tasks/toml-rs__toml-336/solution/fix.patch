+                Ok(parsed) => parsed,
+                Err(err) => {
+                    panic!("Unexpected error for {:?}: {:?}", $input, err);
+                }
+            };
+            if $expected.is_nan() {
+                assert!(v.is_nan());
+            } else if $expected.is_infinite() {
+                assert!(v.is_infinite());
+                assert_eq!($expected.is_sign_positive(), v.is_sign_positive());
+            } else {
+                dbg!($expected);
