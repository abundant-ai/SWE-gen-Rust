-    let timeout = async {
-        tokio::time::sleep(tokio::time::Duration::from_secs(1)).await;
-    };
-
-    let timer = rt.spawn(async {
-        loop {
-            tokio::time::sleep(tokio::time::Duration::from_nanos(1)).await;
-        }
-    });
-
-    let dump = async {
-        loop {
-            let handle = Handle::current();
-            let _dump = handle.dump().await;
-        }
-    };
-
-    rt.block_on(async {
-        tokio::select!(
