+
+        fn visit_string<E>(self, v: String) -> Result<Self::Value, E>
+            where E: Error
+        {
+            Ok(Cow::Owned(v.into_bytes()))
+        }
+
+        fn visit_bytes<E>(self, v: &[u8]) -> Result<Self::Value, E>
