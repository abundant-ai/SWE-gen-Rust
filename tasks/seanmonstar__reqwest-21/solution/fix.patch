+    /// the redirect status code set.
+    ///
+    /// A `Body` constructed from a set of bytes, like `String` or `Vec<u8>`,
+    /// are stored differently and can be reused.
     pub fn new<R: Read + 'static>(reader: R) -> Body {
         Body {
