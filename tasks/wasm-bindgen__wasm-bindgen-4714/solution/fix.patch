+impl TryFromJsValue for bool {
+    type Error = JsValue;
+
+    fn try_from_js_value(value: JsValue) -> Result<Self, Self::Error> {
+        match value.as_bool() {
+            Some(s) => Ok(s),
+            None => Err(value),
+        }
+    }
+}
+
+impl TryFromJsValue for char {
+    type Error = JsValue;
+
+    fn try_from_js_value(value: JsValue) -> Result<Self, Self::Error> {
+        match value.as_string() {
+            Some(s) => {
+                if s.len() == 1 {
+                    Ok(s.chars().nth(0).unwrap())
+                } else {
+                    Err(value)
+                }
+            }
+            None => Err(value),
+        }
+    }
+}
