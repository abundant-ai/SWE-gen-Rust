+
+impl<'a, C: Cardinality> From<Payload<'a>> for PayloadU24<'a, C> {
+    fn from(value: Payload<'a>) -> Self {
+        debug_assert!(value.bytes().len() >= C::MIN);
+        Self(value, PhantomData)
+    }
+}
+
+impl<C: Cardinality> AsRef<[u8]> for PayloadU24<'_, C> {
+    fn as_ref(&self) -> &[u8] {
