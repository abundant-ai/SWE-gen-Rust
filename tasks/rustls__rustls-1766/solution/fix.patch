+            return Some(ring::default_provider());
+        }
+
+        #[cfg(all(feature = "aws_lc_rs", not(feature = "ring")))]
+        {
+            return Some(aws_lc_rs::default_provider());
+        }
+
+        #[allow(unreachable_code)]
+        None
